{
  "name": "payzen",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "postinstall": "prisma generate --schema=packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "turbo": "latest",
    "prisma": "^7.8.0",
    "prettier": "^3.0.0"
  }
}
